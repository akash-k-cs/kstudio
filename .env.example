# ===========================================
# Code Studio Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database
# ===========================================
MONGODB_URI=mongodb://localhost:27017/kstudio

# ===========================================
# GitHub OAuth
# ===========================================
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# API Server
# ===========================================
PORT=4000
FRONTEND_URL=http://localhost:3000

# ===========================================
# Workspaces
# ===========================================
WORKSPACES_DIR=/tmp/kstudio-workspaces

# ===========================================
# OpenCode API (optional)
# ===========================================
OPENCODE_API_URL=https://api.opencode.io
OPENCODE_API_KEY=your_opencode_api_key

# ===========================================
# Railway API (optional)
# ===========================================
RAILWAY_API_URL=https://backboard.railway.app/graphql/v2
RAILWAY_API_TOKEN=your_railway_api_token

# ===========================================
# Frontend (Vite) - prefix with VITE_
# ===========================================
VITE_PORT=3000
VITE_API_URL=http://localhost:4000
